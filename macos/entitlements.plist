<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app bundles third-party dylibs (mpv + its libraries). They are
         signed with the same Developer ID, but mpv also dlopen()s some at
         runtime, so allow loading libraries not signed by the main team. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
